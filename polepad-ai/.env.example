# ============================================================
# PolePad AI — Environment Configuration
# Copy this to .env and edit as needed
# For local demo: defaults work out of the box
# ============================================================

# --- Core ---
ENVIRONMENT=development
SECRET_KEY=local-dev-secret-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://polepad:polepad@postgres:5432/polepad
POSTGRES_USER=polepad
POSTGRES_PASSWORD=polepad
POSTGRES_DB=polepad

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Internal Services ---
CV_SERVICE_URL=http://cv-service:8001
OCR_SERVICE_URL=http://ocr-service:8002

# --- Model Config ---
MODEL_PATH=ml/models/demo/best.pt
MODEL_VERSION=demo-v1.0.0
# YOLO confidence threshold (0.0-1.0)
DETECTION_CONFIDENCE_THRESHOLD=0.45
# OCR character confidence below this = highlighted as uncertain
OCR_UNCERTAINTY_THRESHOLD=0.75

# --- Image Storage ---
# local = store in /data/images inside container
# s3 = store in AWS S3 (set S3_* vars below)
IMAGE_STORAGE_BACKEND=local
LOCAL_IMAGE_DIR=/data/images

# S3 (only needed if IMAGE_STORAGE_BACKEND=s3)
S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=polepad-images

# ============================================================
# DOMINION ENERGY INTEGRATIONS (all off by default)
# ============================================================

# --- Esri ArcGIS Enterprise ---
# Set ARCGIS_ENABLED=true to push confirmed assets to ArcGIS Feature Service
ARCGIS_ENABLED=false
ARCGIS_BASE_URL=https://your-arcgis-server.com/arcgis
ARCGIS_USERNAME=
ARCGIS_PASSWORD=
ARCGIS_FEATURE_SERVICE_URL=https://your-arcgis-server.com/arcgis/rest/services/PoleAssets/FeatureServer/0
ARCGIS_TOKEN_URL=https://your-arcgis-server.com/arcgis/tokens/generateToken

# --- AVEVA PI System ---
# Set PI_SYSTEM_ENABLED=true to write inspection events to PI
PI_SYSTEM_ENABLED=false
PI_BASE_URL=https://your-pi-server.com/piwebapi
PI_USERNAME=
PI_PASSWORD=
PI_DATABASE=PolePad
PI_ASSET_SERVER=your-af-server
# PI tag naming template: {normalized_tag}.{attribute}
PI_TAG_TEMPLATE={tag}.{attribute}

# --- SAP / EpochField Work Orders ---
# Set SAP_ENABLED=true to create work orders for safety-relevant findings
SAP_ENABLED=false
SAP_BASE_URL=https://your-sap-server.com/api
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=
SAP_PLANT_CODE=UTIL
SAP_WORK_ORDER_TYPE=PM01
# Comma-separated attribute classes that trigger work orders
SAP_TRIGGER_CLASSES=vegetation_contact,structural_damage,safety_equipment_missing

# ============================================================
# FRONTEND
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=PolePad AI
